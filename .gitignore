# ===========================================
# Hexo 博客项目 .gitignore
# ===========================================

# -------------------------------------------
# Hexo 生成的文件（不要提交到源码分支）
# -------------------------------------------
public/
.deploy*/
.deploy_git/
.db.json

# 如果你使用 .deploy_git 方式部署，这个目录会在部署时自动生成
# 源码分支（main）不需要包含它

# -------------------------------------------
# Node.js 依赖
# -------------------------------------------
node_modules/
package-lock.json

# -------------------------------------------
# 构建产物
# -------------------------------------------
dist/
build/

# -------------------------------------------
# 日志文件
# -------------------------------------------
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*

# -------------------------------------------
# 运行时数据
# -------------------------------------------
pids/
*.pid
*.seed
*.pid.lock

# -------------------------------------------
# 目录缓存
# -------------------------------------------
.cache/
.CACHE/

# -------------------------------------------
# 环境变量（敏感信息）
# -------------------------------------------
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env.*.local

# -------------------------------------------
# IDE 和编辑器
# -------------------------------------------
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# -------------------------------------------
# 临时文件
# -------------------------------------------
*.tmp
*.temp
.tmp/
temp/

# -------------------------------------------
# 测试覆盖率
# -------------------------------------------
coverage/
.nyc_output/

# -------------------------------------------
# TypeScript 编译输出
# -------------------------------------------
*.tsbuildinfo

# -------------------------------------------
# SASS 编译缓存
# -------------------------------------------
.sass-cache/

# -------------------------------------------
# Hexo 特定忽略
# -------------------------------------------
 scaffolds/
 source/_drafts/
 .hovercmd/
 .md百宝箱*/

# -------------------------------------------
# GitHub Actions 工作流（如果不需要可以注释掉）
# -------------------------------------------
#.github/workflows/

# -------------------------------------------
# 备份文件
# -------------------------------------------
*.bak
*.backup
*_backup/

# -------------------------------------------
# Hexo 部署临时目录（如果使用脚本部署）
# -------------------------------------------
# temp-gh-pages/
